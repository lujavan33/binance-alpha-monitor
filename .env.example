# ================================
# Binance Alpha Monitor - 环境变量
# 本地运行复制为 .env，systemd 运行可复制为 .env.systemd
# ================================

# Telegram 推送配置（必填）
# 1. 在 Telegram 找 @BotFather，发 /newbot 创建 bot
# 2. 给 bot 发一条消息
# 3. 访问 https://api.telegram.org/bot<TOKEN>/getUpdates 找 chat.id
TG_BOT_TOKEN=你的Bot Token
TG_CHAT_ID=你的Chat ID

# Anthropic API 配置（可选，不填则降级为规则引擎）
# 申请地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=你的Anthropic API Key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# 数据库路径（可选）
# DB_PATH=/path/to/alpha.db
